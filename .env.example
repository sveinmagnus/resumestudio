# ─── Resume Studio — environment configuration ───────────────────────────────
# Copy this file to .env and fill in the values.

# API authentication token.
# Required when deploying to a VPS (accessible from the internet).
# Leave empty for local development — auth is disabled when this is unset.
# Generate a strong token: openssl rand -hex 32
RESUME_API_TOKEN=

# Small-team attribution (optional): named tokens as comma-separated name:token
# pairs, e.g. RESUME_API_TOKENS=kari:f3a9...,ola:7bc1...
# Each name is stamped as saved_by on saves and shown in History and on the
# picker cards. Attribution only — every valid token has the same full access.
# Can be set alongside RESUME_API_TOKEN (which stays anonymous).
RESUME_API_TOKENS=

# HTTP port the server listens on.
# Default: 3001 (the desktop launcher auto-picks the next free port if taken).
PORT=3001

# ─── Desktop / self-deployed build (optional) ────────────────────────────────
# These only matter for the downloadable desktop build (npm run build:desktop /
# npm run desktop). The VPS build ignores them. All have sensible defaults.
#
# Where the live SQLite database + log file live. Defaults to a per-user OS
# folder (%APPDATA%\ResumeStudio on Windows, ~/Library/Application Support/
# ResumeStudio on macOS, ~/.local/share/resume-studio on Linux). Override only
# if you want the data somewhere specific.
# RESUME_DATA_DIR=

# Folder for the portable whole-store JSON backup used to sync across computers.
# Point this at a Google Drive / Dropbox / OneDrive folder: Resume Studio keeps
# one backup file there and merges newer content from it on every launch. The
# LIVE database stays in RESUME_DATA_DIR — only the safe JSON file syncs.
# RESUME_BACKUP_DIR=

# How often (ms) the running app refreshes the backup file when the store has
# changed. Default: 60000 (1 min). It also writes once at startup and shutdown.
# RESUME_BACKUP_INTERVAL_MS=60000

# SQLite journal mode. Default WAL (fast, best for a local data dir). If you
# deliberately relocate the LIVE database into a cloud-synced folder (not
# recommended — see RESUME_BACKUP_DIR for the safe path), set this to TRUNCATE
# so no -wal/-shm sidecar files are left for the sync client to corrupt.
# RESUME_DB_JOURNAL=WAL

# ─── API rate limiting (optional) ────────────────────────────────────────────
# The auth-gated API has a failure-focused rate limiter: only responses with
# status >= 400 count against the window, so it brakes bearer-token brute-force
# and bad-request floods WITHOUT throttling a consultant's legitimate auto-save
# traffic (a steady stream of 2xx PUTs). Defaults are usually fine; tune for a
# more- or less-exposed deployment.
# Max counted failures per window per IP. Default: 50
RESUME_RATE_LIMIT_MAX=50
# Window length in milliseconds. Default: 900000 (15 minutes)
RESUME_RATE_LIMIT_WINDOW_MS=900000

# Reverse-proxy trust. Set ONLY when the server sits behind a proxy
# (nginx/caddy/Cloudflare) that sets X-Forwarded-For — otherwise the rate
# limiter keys every request on the proxy's IP instead of the real client IP.
# Value: a hop count ("1" for a single proxy), "true", or an Express preset
# such as "loopback". Leave EMPTY for a direct-bind server (dev / desktop) so a
# spoofable header is never trusted. Default: off.
# RESUME_TRUST_PROXY=1

# ─── Translation assist (optional) ───────────────────────────────────────────
# When a provider is configured, the editor shows a "Draft translation" button
# on the secondary-language input that proxies through this server (CV text only
# travels server→provider). Leave it off and the "Copy from primary" button
# still works. NOTE: in the DESKTOP build you don't set any of this here — use
# the in-app Settings screen (gear icon), which also starts/stops local Docker.
#
# Which backend to use: off | libretranslate | deepl | google | azure | llm.
# "llm" carries no config of its own — it translates with the same model the
# AI-assist section below configures (zero extra setup once Summarize works).
# If unset but LIBRETRANSLATE_URL is set, it defaults to "libretranslate"
# (back-compat with older deployments).
TRANSLATE_PROVIDER=

# -- LibreTranslate (self-hosted) --
# Base URL of a LibreTranslate instance. Easiest locally: `npm run dev:translate`
# (Docker), then set this to http://localhost:5000 and restart the server.
LIBRETRANSLATE_URL=
# Optional API key, if your LibreTranslate instance requires one.
LIBRETRANSLATE_API_KEY=
# Which language models the bundled Docker LibreTranslate installs (service
# codes, comma-separated; each is a few hundred MB). Read by docker-compose.yml
# at container start. English is always needed — Argos pivots through it.
# Default: en,nb,sv,da. The desktop build manages this from Settings instead.
# LT_LOAD_ONLY=en,nb,sv,da

# -- DeepL --  (TRANSLATE_PROVIDER=deepl). Free vs Pro is auto-detected from the
# key suffix (Free keys end in ':fx'). Best quality for Nordic languages.
DEEPL_API_KEY=

# -- Google Cloud Translation v2 --  (TRANSLATE_PROVIDER=google)
GOOGLE_TRANSLATE_API_KEY=

# -- Microsoft Azure Translator --  (TRANSLATE_PROVIDER=azure). Needs the key
# AND the resource region (e.g. westeurope).
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=

# Translation rate limit (optional). Unlike the main API limiter, this one
# counts SUCCESSFUL calls too — a successful draft can cost money on a paid
# provider key, so this caps calls per window to stop a leaked token running up
# the bill. Defaults are far above human drafting pace. The same limiter also
# covers the Summarize and AI-assist endpoints below (same billable backend).
# Max translate calls per window per IP. Default: 60
# RESUME_TRANSLATE_RATE_LIMIT_MAX=60
# Window length in milliseconds. Default: 60000 (1 minute)
# RESUME_TRANSLATE_RATE_LIMIT_WINDOW_MS=60000

# ─── AI assist / Summarize (optional) ────────────────────────────────────────
# One LLM backend powers every AI feature: one-line summaries ("Summarize"),
# the "Run with my AI" buttons (view tailoring, AI import, bulk add, skill
# suggestions, highlights, anonymization check, page-fit advice), and — when
# TRANSLATE_PROVIDER=llm — translation drafts. Everything proxies through this
# server; the browser never talks to the model directly, and the UI tells the
# user whether content stays on the machine (a localhost endpoint) or leaves it.
# Leave the provider unset and every AI button simply stays hidden; the manual
# copy-prompt-into-your-own-AI path always works regardless.
# NOTE: the DESKTOP build manages all of this from in-app Settings, not here.
#
# Which backend: off | ollama | openai | anthropic | gemini | mistral | compat.
#   ollama    — a local (or remote) Ollama; the bundled docker-compose.yml has an
#               `ollama` service (`docker compose up -d ollama`).
#   openai    — the OpenAI API (needs SUMMARIZE_OPENAI_API_KEY).
#   anthropic — the Anthropic (Claude) API, native Messages endpoint
#               (needs SUMMARIZE_ANTHROPIC_API_KEY).
#   gemini    — Google Gemini via its OpenAI-compatible endpoint
#               (needs SUMMARIZE_GEMINI_API_KEY).
#   mistral   — the Mistral API (needs SUMMARIZE_MISTRAL_API_KEY).
#   compat    — any other OpenAI-compatible endpoint (LM Studio, Groq, OpenRouter,
#               Together, …) via SUMMARIZE_COMPAT_URL (+ optional key).
SUMMARIZE_PROVIDER=
# Chat model name, e.g. "llama3.2:3b" (Ollama), "gpt-4o-mini" (OpenAI),
# "claude-haiku-4-5" (Anthropic), "gemini-2.5-flash" (Gemini), or
# "mistral-small-latest" (Mistral). Hosted providers fall back to a sensible
# default when blank; Ollama/compat need it set.
SUMMARIZE_MODEL=
# -- ollama --  Base URL without /v1. Default: http://localhost:11434
# SUMMARIZE_OLLAMA_URL=http://localhost:11434
# -- openai --
# SUMMARIZE_OPENAI_API_KEY=
# -- anthropic --
# SUMMARIZE_ANTHROPIC_API_KEY=
# -- gemini --
# SUMMARIZE_GEMINI_API_KEY=
# -- mistral --
# SUMMARIZE_MISTRAL_API_KEY=
# -- compat --  Base URL of the OpenAI-compatible endpoint (with /v1 if the
# service expects it), plus an optional API key.
# SUMMARIZE_COMPAT_URL=
# SUMMARIZE_COMPAT_API_KEY=
