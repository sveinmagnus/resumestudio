{
  "name": "resume-manager",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,yellow \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:translate": "docker compose up -d libretranslate",
    "translate:down": "docker compose stop libretranslate",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "desktop": "npm run build && tsx server/desktop/launcher.ts",
    "build:desktop": "npm run build && node scripts/build-desktop.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "better-sqlite3": "^12.10.0",
    "docx": "^9.7.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "fflate": "^0.8.3",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "systray2": "^2.1.4",
    "uuid": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.0",
    "esbuild": "^0.28.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vitest": "^4.1.7"
  }
}
